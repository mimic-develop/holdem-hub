# Hub / API
# 기본 포트는 vite.config.ts / api/src/index.ts에 하드코딩되어 있다.
# 아래 값을 채우면 dev 서버가 그 포트를 사용한다 (override).
VITE_API_BASE_URL=http://localhost:3002
HUB_PORT=5175
API_PORT=3002

# Mock 모드 — true면 MSW가 모든 /api 요청을 가로채 정적 mock으로 응답하고,
# auth도 자동 로그인 상태가 된다. API 서버/로그인 없이 프론트 개발 가능.
# 개인 설정은 .env.local(gitignore)에 VITE_MOCK=true로 두고 `pnpm dev:hub` 실행.
VITE_MOCK=false

# Auth provider — 'mimic' (MIMIC 서버) | 'firebase' (concept-quiz) | 'none'
VITE_AUTH_PROVIDER=mimic

# MIMIC 서버 인증 (VITE_AUTH_PROVIDER=mimic)
VITE_MIMIC_API_URL=http://localhost:48081/api
VITE_MIMIC_CLIENT_ID=mimic-web
VITE_MIMIC_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=

# Firebase (VITE_AUTH_PROVIDER=firebase, concept-quiz)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# PeerJS broker overrides (heads-up). Leave blank to use public broker.
VITE_PEERJS_HOST=
VITE_PEERJS_PORT=
VITE_PEERJS_PATH=
VITE_PEERJS_SECURE=
VITE_PEERJS_KEY=

# Future: Mimic OAuth
# VITE_MIMIC_AUTH_URL=
